# tide self-host — docker-compose secrets
#
# Copy to .env, fill in, then: docker compose up -d

# --- public-facing -----------------------------------------------------------

# Hostname that Traefik will route to (set an A record at your DNS provider).
TIDE_HOST=tide.example.com
LETSENCRYPT_EMAIL=you@example.com

# Image tag — pin to a release in production. `latest` is fine for tinkering.
TIDE_IMAGE_TAG=v0.1.0

# --- secrets ----------------------------------------------------------------

# Must be 32+ characters. `openssl rand -base64 32` is fine.
AUTH_SECRET=replace-with-32-bytes-of-secret-padding

POSTGRES_PASSWORD=replace-me-please

MINIO_ROOT_USER=tide-minio
MINIO_ROOT_PASSWORD=replace-me-please-too

# --- AI providers (optional, but recommended) -------------------------------

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

VOYAGE_API_KEY=
OPENAI_API_KEY=

# --- email (optional) -------------------------------------------------------

RESEND_API_KEY=
EMAIL_FROM=tide <hello@tide.example.com>
EMAIL_INBOUND_DOMAIN=tide.example.com
RESEND_INBOUND_WEBHOOK_SECRET=

# --- oauth (optional) -------------------------------------------------------

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- rate limiting (optional, Upstash) --------------------------------------

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- feature flags ----------------------------------------------------------

FLAG_BIONIC_READING=1
FLAG_LISTEN_MODE=1
FLAG_PUBLIC_SHARING=1
FLAG_WEEKLY_DIGEST=
