# tide v0.1 — exhaustive env example
# All values are validated at boot via Zod. Missing required vars = hard fail.

# ─────────────────────────────────────────────────────────
# core
# ─────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 32+ char random. Generate with: openssl rand -hex 32
AUTH_SECRET=replace-me-with-openssl-rand-hex-32

# ─────────────────────────────────────────────────────────
# database
#   DATABASE_DRIVER=postgres → DATABASE_URL is required (full vector + search)
#   DATABASE_DRIVER=sqlite   → DATABASE_FILE path (solo self-host)
# ─────────────────────────────────────────────────────────
DATABASE_DRIVER=postgres
DATABASE_URL=postgres://tide:tide@localhost:5432/tide_dev
DATABASE_FILE=./data/tide.sqlite

# ─────────────────────────────────────────────────────────
# redis (bullmq queue + rate-limit fanout)
# ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# Optional: hosted Upstash for production rate-limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────
# auth providers (all optional; magic-link works without these)
# ─────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────
# ai providers
# ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Primary embeddings
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5

# Fallback embeddings (used when VOYAGE_API_KEY is unset or rate-limited)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─────────────────────────────────────────────────────────
# email (Resend) — transactional + weekly digest + inbound save
# ─────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="tide <hello@tide.example>"
EMAIL_INBOUND_DOMAIN=tide.example
RESEND_INBOUND_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────
# storage (archived HTML)
#   STORAGE_DRIVER=r2     → CF R2 / any S3-compatible
#   STORAGE_DRIVER=minio  → self-host MinIO (same env shape)
#   STORAGE_DRIVER=local  → filesystem path (standalone build)
# ─────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./data/archive

STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_BUCKET=tide-archive
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=

# ─────────────────────────────────────────────────────────
# capture
# ─────────────────────────────────────────────────────────
SAVE_RATE_LIMIT_PER_USER_HOURLY=120
SAVE_RATE_LIMIT_PER_IP_HOURLY=240

# ─────────────────────────────────────────────────────────
# feature flags
# ─────────────────────────────────────────────────────────
FLAG_BIONIC_READING=1
FLAG_LISTEN_MODE=1
FLAG_PUBLIC_SHARING=1
FLAG_WEEKLY_DIGEST=1
